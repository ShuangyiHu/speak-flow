# ── Anthropic (required) ──────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub (required for PR integration) ─────────────────────────────────────
# Create token at: https://github.com/settings/tokens
# Required scopes: repo (full), workflow
GITHUB_TOKEN=ghp_...
# Format: your-username/your-repo-name  (no https://, no .git)
GITHUB_REPO=your-username/speak-flow

# ── LangSmith (optional — for tracing CrewAI + LangGraph calls) ──────────────
# Sign up at: https://smith.langchain.com
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=speakflow

# ── Development flags ─────────────────────────────────────────────────────────
# Set True to skip Montreal Forced Aligner (run without MFA installed locally)
USE_STUB_MFA=True
